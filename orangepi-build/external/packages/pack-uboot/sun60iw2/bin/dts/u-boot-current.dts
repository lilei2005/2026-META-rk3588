			id = <0x03>;
			power-domains = <0x13 0x03>;
		};

		dummy04 {
			iommu-master;
			id = <0x04>;
			skip;
		};

		dummy05 {
			iommu-master;
			id = <0x05>;
			skip;
		};

		ve_dec0_iommu {
			iommu-master;
			id = <0x06>;
