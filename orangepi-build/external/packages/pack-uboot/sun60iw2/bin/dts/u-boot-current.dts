		cpu-map {

			cluster0 {

				core0 {
					cpu = <0x0a>;
				};

				core1 {
					cpu = <0x0b>;
				};

				core2 {
					cpu = <0x0c>;
				};

				core3 {
					cpu = <0x0d>;
				};

				core4 {
					cpu = <0x0e>;
				};

				core5 {
					cpu = <0x0f>;
				};
