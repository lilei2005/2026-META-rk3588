			method = "smc";
		};
	};

	arm_pmu {
		compatible = "arm,armv8-pmuv3";
		interrupt-parent = <0x02>;
		interrupts = <0x01 0x07 0x04>;
	};

	cpus {
		#address-cells = <0x02>;
