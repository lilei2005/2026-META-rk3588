			enable-method = "psci";
			cpu-idle-states = <0x03 0x04>;
			capacity-dmips-mhz = <0x1ae>;
			clocks = <0x05 0x01>;
			operating-points-v2 = <0x06>;
			dynamic-power-coefficient = <0xa2>;
			#cooling-cells = <0x02>;
			cpu-supply = <0x07>;
			phandle = <0x0a>;
		};

		cpu@100 {
			device_type = "cpu";
			compatible = "arm,cortex-a55";
			reg = <0x00 0x100>;
			enable-method = "psci";
			cpu-idle-states = <0x03 0x04>;
			capacity-dmips-mhz = <0x1ae>;
			clocks = <0x05 0x01>;
			operating-points-v2 = <0x06>;
			dynamic-power-coefficient = <0xa2>;
			#cooling-cells = <0x02>;
			phandle = <0x0b>;
